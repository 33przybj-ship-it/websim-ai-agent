# ── API Provider (OpenAI-compatible) ──
# Point this at any OpenAI-compatible endpoint
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=claude-opus-4-8-20260501
# Does your endpoint support image/vision input?
OPENAI_VISION_SUPPORT=false

# ── websim auth ──
# Grab from browser devtools while logged into websim.com:
# Network tab → any api/v1 request → Authorization: Bearer <this>
WEBSIM_BEARER=YOUR_WEBSIM_JWT_HERE

# ── Agent settings ──
# Bot's websim username — used to skip its own comments (prevents self-reply loops)
WEBSIM_BOT_USERNAME=Opus_4_8
# Max tool-calling loop iterations
AGENT_MAX_TURNS=15
# Polling interval in seconds (10 = check every 10s)
AGENT_WATCH_INTERVAL_SECONDS=10
# Auto-prune state entries older than this many days
AGENT_STATE_MAX_AGE_DAYS=90
# Verbose logging
AGENT_DEBUG=false
